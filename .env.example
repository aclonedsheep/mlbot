MLB_IRC_NICK=mlbbot
MLB_IRC_SERVER=irc.example.net
MLB_IRC_PORT=6697
MLB_IRC_TLS=true
MLB_IRC_CHANNEL=#mlb
MLB_IRC_REALNAME=MLB IRC Bot
MLB_COMMAND_PREFIX=@
MLB_TIMEZONE=America/New_York
MLB_DATABASE_PATH=data/mlb_irc_bot.sqlite3
MLB_HTTP_TIMEOUT_SECONDS=10
MLB_SCHEDULE_POLL_SECONDS=300
MLB_ACTIVE_GAME_POLL_SECONDS=15
MLB_NEAR_START_POLL_SECONDS=60
MLB_ENABLE_ALERT_HOME_RUNS=true
MLB_ENABLE_ALERT_SCORING=true
MLB_ENABLE_ALERT_BASES_LOADED=true
MLB_ENABLE_ALERT_FINALS=true
MLB_ENABLE_ALERT_NO_HITTER=true
MLB_ENABLE_ALERT_IMMACULATE=true
MLB_ENABLE_ALERT_CYCLE=true
MLB_ENABLE_ALERT_WIN_PROBABILITY=true
MLB_ENABLE_ALERT_HIGH_LEVERAGE=true
MLB_ENABLE_ALERT_HARD_HIT=true
MLB_ENABLE_ALERT_BARREL=true
MLB_ENABLE_ALERT_LATE_THREAT=true
MLB_ENABLE_ALERT_WEATHER=true
MLB_ALERT_HARD_HIT_THRESHOLD_MPH=110
MLB_ALERT_WIN_PROBABILITY_THRESHOLD=15
MLB_ALERT_HIGH_LEVERAGE_THRESHOLD=2.5
